@{
    ViewData["Title"] = "Buscador Global";
    var resultadosJson = ViewBag.Resultados as string;
    var total = (int)(ViewBag.Total ?? 0);
    var query = ViewBag.Query as string ?? "";
}

<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <h2 class="mb-1 fw-bold" style="font-size:1.4rem;">
            <i class="fas fa-search me-2" style="color:var(--accent);"></i>Documentos Vigentes
        </h2>
        <span class="text-muted" style="font-size:.85rem;">
            @total documento(s) encontrado(s)
        </span>
    </div>
</div>

@* Barra de búsqueda *@
<div class="sigd-card mb-4">
    <form method="get" asp-action="Global" class="d-flex gap-2">
        <input type="text" name="q" value="@query" class="form-control"
               placeholder="Buscar por título, etiqueta o contenido...">
        <button type="submit" class="btn btn-primary px-4">
            <i class="fas fa-search me-1"></i>Buscar
        </button>
        @if (!string.IsNullOrEmpty(query))
        {
            <a asp-action="Global" class="btn btn-secondary">
                <i class="fas fa-times me-1"></i>Limpiar
            </a>
        }
    </form>
</div>

@* Tabla de resultados *@
<div class="sigd-card">
    @if (resultadosJson != null)
    {
        var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
        var resultado = System.Text.Json.JsonSerializer.Deserialize<System.Text.Json.JsonElement>(resultadosJson);
        var docs = resultado.GetProperty("data").EnumerateArray().ToList();
        int porPagina = 10;
        int paginaActual = 1;
        if (int.TryParse(Context.Request.Query["pagina"], out int p) && p > 0)
            paginaActual = p;
        int totalPaginas = (int)Math.Ceiling(docs.Count / (double)porPagina);
        var docsPaginados = docs.Skip((paginaActual - 1) * porPagina).Take(porPagina).ToList();

        if (docs.Count == 0)
        {
            <div class="text-center py-5">
                <i class="fas fa-search fa-3x mb-3" style="color:var(--border);"></i>
                <p class="text-muted">No se encontraron documentos para "@query".</p>
                <a asp-action="Global" class="btn btn-outline-primary">Ver todos</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Título</th>
                            <th>Versión</th>
                            <th>Etiquetas</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in docsPaginados)
                        {
                            var codigo = doc.TryGetProperty("codigo_interno", out var c) ? c.GetString() : "—";
                            var titulo = doc.TryGetProperty("titulo", out var t) ? t.GetString() : "—";
                            var version = doc.TryGetProperty("version", out var v) ? v.GetInt32() : 1;
                            var idSql = doc.TryGetProperty("id_documento_sql", out var id) ? id.GetInt32() : 0;
                            var tags = doc.TryGetProperty("tags", out var tg)
                                ? string.Join(", ", tg.EnumerateArray().Select(x => x.GetString()))
                                : "—";
                            <tr>
                                <td><code style="color:var(--accent2);">@codigo</code></td>
                                <td class="fw-semibold">@titulo</td>
                                <td><span class="badge bg-primary">v@(version)</span></td>
                                <td><small class="text-muted">@tags</small></td>
                                <td class="text-center">
                                    <a asp-controller="Documento" asp-action="DescargarUltima"
                                       asp-route-id="@idSql"
                                       class="btn btn-sm btn-outline-success">
                                        <i class="fas fa-download me-1"></i>Descargar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (totalPaginas > 1)
            {
                <div class="d-flex justify-content-between align-items-center mt-3 px-1">
                    <small class="text-muted">
                        Página @paginaActual de @totalPaginas (@docs.Count documentos en total)
                    </small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                <a class="page-link" href="?q=@query&pagina=@(paginaActual - 1)">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = 1; i <= totalPaginas; i++)
                            {
                                <li class="page-item @(i == paginaActual ? "active" : "")">
                                    <a class="page-link" href="?q=@query&pagina=@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                <a class="page-link" href="?q=@query&pagina=@(paginaActual + 1)">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-exclamation-circle fa-3x mb-3" style="color:var(--warning);"></i>
            <p class="text-muted">El servicio de búsqueda no está disponible en este momento.</p>
        </div>
    }
</div>
