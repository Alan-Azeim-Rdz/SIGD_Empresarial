@using System.Linq
@using System.Security.Claims
@{
    ViewData["Title"] = "Inicio";
}

<div class="py-4">
    <h1 class="display-5 text-center">Panel de Control</h1>
    <p class="text-center text-muted">Bienvenido al Sistema Integral de Gestión Documental (SIGD)</p>
</div>

@if (!User.Identity.IsAuthenticated)
{
    <div class="text-center">
        <p>Por favor <a asp-controller="Auth" asp-action="Login">inicia sesión</a> para acceder a las funciones del sistema.</p>
    </div>
}
else
{
    <div class="mb-3">
        <strong>Usuario:</strong> @User.Identity.Name
        <br />
        <strong>Roles:</strong> @string.Join(", ", User.Claims.Where(c => c.Type == ClaimTypes.Role).Select(c => c.Value))
    </div>

    <div class="row g-3">
        @* Administrador *@
        @if (User.IsInRole("Administrador"))
        {
            <div class="col-md-4">
                <div class="card card-jewel p-3 h-100">
                    <h5 class="card-title">Administración</h5>
                    <p class="card-text">Gestiona usuarios, roles y parámetros del sistema.</p>
                    <a class="btn btn-jewel-primary" asp-controller="Auth" asp-action="Usuarios">Gestionar Usuarios</a>
                    <a class="btn btn-outline-secondary ms-2" asp-controller="Auth" asp-action="Registro">Crear Usuario</a>
                </div>
            </div>
        }

        @* Superior / Aprobador *@
        @if (User.IsInRole("Superior") || User.IsInRole("Aprobador"))
        {
            <div class="col-md-4">
                <div class="card card-jewel p-3 h-100">
                    <h5 class="card-title">Aprobación y Revisión</h5>
                    <p class="card-text">Revisa y aprueba documentos pendientes en tu bandeja.</p>
                    <a class="btn btn-jewel-primary" asp-controller="Flujo" asp-action="Pendientes">Ver Pendientes</a>
                </div>
            </div>
        }

        @* Editor / Usuario *@
        @if (User.IsInRole("Editor") || User.IsInRole("Usuario"))
        {
            <div class="col-md-4">
                <div class="card card-jewel p-3 h-100">
                    <h5 class="card-title">Gestión de Documentos</h5>
                    <p class="card-text">Crea, edita y envía documentos para aprobación.</p>
                    <a class="btn btn-jewel-primary" asp-controller="Documento" asp-action="Crear">Crear Documento</a>
                    <a class="btn btn-outline-secondary ms-2" asp-controller="Documento" asp-action="Index">Mis Documentos</a>
                </div>
            </div>
        }

        @* Normativas *@
        @if (User.IsInRole("Administrador") || User.IsInRole("Editor") || User.IsInRole("Usuario"))
        {
            <div class="col-md-4">
                <div class="card card-jewel p-3 h-100">
                    <h5 class="card-title">Portal de Normativas</h5>
                    <p class="card-text">Consulta y firma normativas y procedimientos vigentes en planta.</p>
                    <a class="btn btn-jewel-primary" href="http://localhost:8000/index.php?action=portal" target="_blank">Ir al Portal</a>
                </div>
            </div>
        }

        @* Reportes *@
        @if (User.IsInRole("Administrador") || User.IsInRole("Auditor"))
        {
            <div class="col-md-4">
                <div class="card card-jewel p-3 h-100">
                    <h5 class="card-title">Reportes y KPIs</h5>
                    <p class="card-text">Genera reportes de estado, flujo de aprobación y auditoría en tiempo real.</p>
                    <a class="btn btn-jewel-primary" href="http://localhost:8000/index.php?action=dashboard" target="_blank">Ir a Reportes</a>
                </div>
            </div>
        }

        @* Bandeja general para cualquier usuario autenticado *@
        <div class="col-md-4">
            <div class="card card-jewel p-3 h-100">
                <h5 class="card-title">Mis Documentos</h5>
                <p class="card-text">Accede a tus documentos creados, borradores y versiones.</p>
                <a class="btn btn-jewel-primary" asp-controller="Documento" asp-action="Index">Ir a Mis Documentos</a>
            </div>
        </div>
    </div>
}

<div class="mt-4 text-muted small">Si alguna opción no está visible es porque tu rol no tiene permiso para esa acción.</div>
