@model Gestion_de_Documentos.Models.Usuario
@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="fw-bold mb-0" style="font-size:1.4rem;">
        <i class="fas fa-user-edit me-2" style="color:var(--accent);"></i>Editar Usuario
    </h2>
</div>

<div class="sigd-card" style="max-width:700px; margin:0 auto;">
    <form asp-action="EditarUsuario" asp-controller="Admin" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Nombre" class="form-label">Nombre(s)</label>
                <input asp-for="Nombre" class="form-control" required />
            </div>
            <div class="col-md-6">
                <label asp-for="ApellidoP" class="form-label">Apellido Paterno</label>
                <input asp-for="ApellidoP" class="form-control" required />
            </div>
            <div class="col-md-6">
                <label asp-for="ApellidoM" class="form-label">Apellido Materno</label>
                <input asp-for="ApellidoM" class="form-control" />
            </div>
            <div class="col-md-6">
                <label asp-for="Correo" class="form-label">Correo Electrónico</label>
                <input asp-for="Correo" type="email" class="form-control" required />
            </div>
            <div class="col-md-6">
                <label asp-for="IdDepartamento" class="form-label">Departamento</label>
                <select asp-for="IdDepartamento" class="form-select" required>
                    <option value="">Seleccione...</option>
                    @foreach (var depto in ViewBag.Departamentos)
                    {
                        <option value="@depto.Id">@depto.Nombre</option>
                    }
                </select>
            </div>
        </div>

        <div class="d-flex justify-content-between mt-4">
            <a asp-controller="Auth" asp-action="Usuarios" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-1"></i>Cancelar
            </a>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save me-1"></i>Guardar Cambios
            </button>
        </div>
    </form>
</div>
