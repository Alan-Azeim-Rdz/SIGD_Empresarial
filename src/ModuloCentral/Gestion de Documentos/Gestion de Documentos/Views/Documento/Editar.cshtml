@model Gestion_de_Documentos.Models.Documento

@{
    ViewData["Title"] = "Editar Documento";
}

<div class="card card-jewel mt-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h3 class="mb-0 text-dark">Editar Metadatos de Documento</h3>
        <span class="badge bg-warning text-dark">@Model.EstadoActual</span>
    </div>
    <div class="card-body">
        <form asp-action="Editar" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="CodigoInterno" class="form-label fw-bold">Código Interno</label>
                    <input asp-for="CodigoInterno" class="form-control" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Titulo" class="form-label fw-bold">Título del Documento</label>
                    <input asp-for="Titulo" class="form-control" required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="IdTipoDocumento" class="form-label fw-bold">Tipo de Documento</label>
                    <select asp-for="IdTipoDocumento" class="form-select" required>
                        <option value="">Seleccione...</option>
                        @foreach(var tipo in ViewBag.TiposDocumento)
                        {
                            <option value="@tipo.Id">@tipo.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="IdDepartamento" class="form-label fw-bold">Departamento Propietario</label>
                    <select asp-for="IdDepartamento" class="form-select" required>
                        <option value="">Seleccione...</option>
                        @foreach(var depto in ViewBag.Departamentos)
                        {
                            <option value="@depto.Id">@depto.Nombre</option>
                        }
                    </select>
                </div>
            </div>

            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> Solo se pueden editar los metadatos. Si necesitas subir un archivo diferente, utiliza la opción <strong>"Subir Nueva Versión"</strong> en la pantalla de Detalles.
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Detalle" asp-route-id="@Model.Id" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-jewel-primary">Guardar Cambios</button>
            </div>
        </form>
    </div>
</div>
