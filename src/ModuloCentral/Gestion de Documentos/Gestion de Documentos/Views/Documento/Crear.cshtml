@model Gestion_de_Documentos.Models.Documento

@{
    ViewData["Title"] = "Crear Documento";
}

<div class="card card-jewel mt-4">
    <div class="card-header bg-white">
        <h3 class="mb-0 text-dark">Subir Nuevo Documento (PDF)</h3>
    </div>
    <div class="card-body">
        <form asp-action="Crear" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="CodigoInterno" class="form-label fw-bold">Código Interno</label>
                    <input asp-for="CodigoInterno" class="form-control" placeholder="Ej. PROC-ADM-001" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Titulo" class="form-label fw-bold">Título del Documento</label>
                    <input asp-for="Titulo" class="form-control" required />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="IdTipoDocumento" class="form-label fw-bold">Tipo de Documento</label>
                    <select asp-for="IdTipoDocumento" class="form-select" required>
                        <option value="">Seleccione...</option>
                        @foreach(var tipo in ViewBag.TiposDocumento)
                        {
                            <option value="@tipo.Id">@tipo.Nombre (@tipo.Abreviatura)</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="IdDepartamento" class="form-label fw-bold">Departamento Propietario</label>
                    <select asp-for="IdDepartamento" class="form-select" required>
                        <option value="">Seleccione...</option>
                        @foreach(var depto in ViewBag.Departamentos)
                        {
                            <option value="@depto.Id">@depto.Nombre</option>
                        }
                    </select>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Archivo Físico (Solo PDF)</label>
                <input type="file" name="archivoPdf" class="form-control" accept=".pdf,application/pdf" required />
                <small class="text-muted">El archivo se guardará automáticamente en MongoDB GridFS garantizando su integridad y estandarización.</small>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                <button type="button" class="btn btn-jewel-primary" id="btnGuardarDoc">
                    <i class="fas fa-save me-1"></i>Guardar como Borrador
                </button>
            </div>
<div class="modal fade" id="modalConfirmarGuardar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-save me-2"></i>Confirmar Guardado</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Estás seguro que deseas guardar este documento como borrador?</p>
                <p class="text-muted small">Podrás editarlo después mientras esté en estado <strong>Borrador</strong>.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnConfirmarGuardar">
                    <i class="fas fa-save me-1"></i>Sí, Guardar
                </button>
            </div>
        </div>
    </div>
</div>
<script>
document.getElementById('btnGuardarDoc').addEventListener('click', function() {
    var modal = new bootstrap.Modal(document.getElementById('modalConfirmarGuardar'));
    modal.show();
});
document.getElementById('btnConfirmarGuardar').addEventListener('click', function() {
    document.querySelector('form').submit();
});
</script>
        </form>
    </div>
</div>
