@model Gestion_de_Documentos.Models.Documento

@{
    ViewData["Title"] = "Detalle del Documento";
}

<div class="card card-jewel mt-4">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h3 class="mb-0 text-dark">Detalle: @Model.Titulo</h3>
        <span class="badge bg-secondary p-2">Estado: @Model.EstadoActual</span>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item"><strong>Código Interno:</strong> @Model.CodigoInterno</li>
                    <li class="list-group-item"><strong>Tipo:</strong> @Model.IdTipoDocumentoNavigation?.Nombre</li>
                    <li class="list-group-item"><strong>Departamento:</strong> @Model.IdDepartamentoNavigation?.Nombre</li>
                    <li class="list-group-item"><strong>Fecha de Creación:</strong> @Model.FechaCreacion?.ToString("dd/MM/yyyy HH:mm")</li>
                </ul>
            </div>
            <div class="col-md-6 mt-4">
                <div class="d-flex flex-column gap-2">
                    @if (Model.EstadoActual == "Borrador")
                    {
                        <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-outline-primary w-100">
                            <i class="fas fa-edit me-2"></i>Editar Metadatos
                        </a>
                        <a asp-action="SubirNuevaVersion" asp-route-id="@Model.Id" class="btn btn-outline-success w-100">
                            <i class="fas fa-file-upload me-2"></i>Subir Nueva Versión
                        </a>
                    }
                    <button type="button" class="btn btn-warning w-100" id="btnEnviarRevision">
                        <i class="fas fa-paper-plane me-2"></i>Enviar a Revisión
                    </button>
                    <a asp-action="Historial" asp-route-id="@Model.Id" class="btn btn-outline-info w-100">
                        <i class="fas fa-history"></i> Ver Historial Completo
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">
                        <i class="fas fa-arrow-left"></i> Volver a Mis Documentos
                    </a>
                </div>
            </div>
        </div>

        <h4 class="mt-5 mb-3 text-jewel-sapphire">Historial de Versiones</h4>
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Versión</th>
                        <th>Fecha Subida</th>
                        <th>Hash (SHA-256)</th>
                        <th>Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var version in Model.DocumentoVersions)
                    {
                        <tr>
                            <td>V@(version.NumeroVersion)</td>
                            <td>@version.FechaSubida?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><small class="text-muted">@version.HashDocumento</small></td>
                            <td>
                                <a asp-action="Descargar" asp-route-versionId="@version.Id" class="btn btn-sm btn-jewel-primary">Descargar PDF</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalConfirmarRevision" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-paper-plane me-2 text-warning"></i>Confirmar Envío a Revisión</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Estás seguro que deseas enviar este documento a revisión?</p>
                <p class="text-warning small"><i class="fas fa-exclamation-circle me-1"></i>Una vez enviado <strong>no podrás editarlo</strong> hasta que sea rechazado por el revisor.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <a asp-controller="Flujo" asp-action="EnviarARevision" asp-route-idDocumento="@Model.Id"
                   class="btn btn-warning" id="btnConfirmarRevision">
                    <i class="fas fa-paper-plane me-1"></i>Sí, Enviar a Revisión
                </a>
            </div>
        </div>
    </div>
</div>
<script>
document.getElementById('btnEnviarRevision').addEventListener('click', function() {
    var modal = new bootstrap.Modal(document.getElementById('modalConfirmarRevision'));
    modal.show();
});
</script>
