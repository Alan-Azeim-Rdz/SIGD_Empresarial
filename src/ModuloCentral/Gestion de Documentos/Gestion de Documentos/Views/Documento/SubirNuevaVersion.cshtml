@model Gestion_de_Documentos.Models.Documento

@{
    ViewData["Title"] = "Subir Nueva Versión";
    var ultimaVersion = Model.DocumentoVersions?.OrderByDescending(v => v.NumeroVersion).FirstOrDefault();
    var versionActual = ultimaVersion?.NumeroVersion ?? 0;
    var nuevaVersion = versionActual + 1;
}

<div class="card card-jewel mt-4">
    <div class="card-header bg-white">
        <h3 class="mb-0 text-dark">Subir Nueva Versión de Documento</h3>
        <p class="text-muted mb-0">Estás por subir la <strong>Versión @nuevaVersion</strong> de "@Model.Titulo"</p>
    </div>
    <div class="card-body">
        <form asp-action="SubirNuevaVersion" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle"></i> La versión anterior (V@(versionActual)) quedará en el historial. Esta nueva versión reemplazará al archivo físico vigente.
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Archivo Físico Nuevo (Solo PDF)</label>
                <input type="file" name="archivoPdf" class="form-control" accept=".pdf,application/pdf" required />
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Detalle" asp-route-id="@Model.Id" class="btn btn-secondary">Cancelar</a>
                <button type="button" class="btn btn-success" id="btnSubirVersion">
                    <i class="fas fa-upload me-1"></i>Subir Nueva Versión
                </button>
            </div>
<div class="modal fade" id="modalConfirmarSubir" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2 text-warning"></i>Confirmar Nueva Versión</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Estás seguro que deseas subir una nueva versión?</p>
                <p class="text-warning small"><i class="fas fa-exclamation-circle me-1"></i>La versión anterior quedará en el historial y esta nueva será la vigente.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" id="btnConfirmarSubir">
                    <i class="fas fa-upload me-1"></i>Sí, Subir Versión
                </button>
            </div>
        </div>
    </div>
</div>
<script>
document.getElementById('btnSubirVersion').addEventListener('click', function() {
    var modal = new bootstrap.Modal(document.getElementById('modalConfirmarSubir'));
    modal.show();
});
document.getElementById('btnConfirmarSubir').addEventListener('click', function() {
    document.querySelector('form').submit();
});
</script>
        </form>
    </div>
</div>
