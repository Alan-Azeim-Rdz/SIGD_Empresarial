@model Gestion_de_Documentos.Models.Documento

@{
    ViewData["Title"] = "Subir Nueva Versión";
    var ultimaVersion = Model.DocumentoVersions?.OrderByDescending(v => v.NumeroVersion).FirstOrDefault();
    var versionActual = ultimaVersion?.NumeroVersion ?? 0;
    var nuevaVersion = versionActual + 1;
}

<div class="card card-jewel mt-4">
    <div class="card-header bg-white">
        <h3 class="mb-0 text-dark">Subir Nueva Versión de Documento</h3>
        <p class="text-muted mb-0">Estás por subir la <strong>Versión @nuevaVersion</strong> de "@Model.Titulo"</p>
    </div>
    <div class="card-body">
        <form asp-action="SubirNuevaVersion" method="post" enctype="multipart/form-data">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle"></i> La versión anterior (V@(versionActual)) quedará en el historial. Esta nueva versión reemplazará al archivo físico vigente.
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Archivo Físico Nuevo (Solo PDF)</label>
                <input type="file" name="archivoPdf" class="form-control" accept=".pdf,application/pdf" required />
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Detalle" asp-route-id="@Model.Id" class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-success"><i class="fas fa-upload"></i> Subir Versión @nuevaVersion</button>
            </div>
        </form>
    </div>
</div>
