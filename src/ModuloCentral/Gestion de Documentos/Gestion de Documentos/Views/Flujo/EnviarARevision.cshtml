@model Gestion_de_Documentos.Models.Documento
@{
    ViewData["Title"] = "Asignar a Revisión";
}
<div class="card card-jewel mt-4">
    <div class="card-header bg-white">
        <h3 class="mb-0 text-dark">Enviar Documento a Revisión</h3>
    </div>
    <div class="card-body">
        <div class="alert alert-info">
            Estás a punto de enviar el documento <strong>@Model.Titulo</strong> a revisión.
            Una vez enviado, no podrás editarlo ni subir nuevas versiones a menos que sea rechazado.
        </div>
        <form asp-action="EnviarARevision" method="post">
            <input type="hidden" name="idDocumento" value="@Model.Id" />
            <div class="mb-3">
                <label class="form-label fw-bold">Seleccionar Revisor (Aprobador)</label>
                <select name="idRevisor" class="form-select" required>
                    <option value="">-- Selecciona a un Superior o Administrador --</option>
                    @foreach (var revisor in ViewBag.Revisores)
                    {
                        <option value="@revisor.Id">@revisor.Nombre @revisor.ApellidoP (@revisor.Rol)</option>
                    }
                </select>
                <small class="text-muted">Solo se muestran usuarios con permiso para aprobar documentos.</small>
            </div>
            <div class="mb-4">
                <label class="form-label fw-bold">
                    <i class="fas fa-comment-alt me-1"></i>Contexto o Descripción (Opcional)
                </label>
                <textarea name="descripcionEnvio" class="form-control" rows="3"
                    placeholder="Ej: Este documento fue actualizado según la nueva normativa ISO. Por favor revisar sección 3..."></textarea>
                <small class="text-muted">Proporciona contexto al revisor para facilitar su evaluación.</small>
            </div>
            <div class="d-flex justify-content-between">
                <a asp-controller="Documento" asp-action="Detalle" asp-route-id="@Model.Id"
                   class="btn btn-secondary">Cancelar</a>
                <button type="submit" class="btn btn-warning text-dark fw-bold">
                    <i class="fas fa-paper-plane me-1"></i>Enviar a Revisión
                </button>
            </div>
        </form>
    </div>
</div>
