@model Gestion_de_Documentos.Models.Usuario
@{
    ViewData["Title"] = "Alta de Usuario";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card card-jewel">
            <div class="card-body p-4">
                <h3 class="fw-bold mb-4" style="color: var(--jewel-amethyst);">
                    Registro de Nuevo Personal
                </h3>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }
                @if (ViewBag.Exito != null)
                {
                    <div class="alert alert-success">@ViewBag.Exito</div>
                }

                <form asp-action="Registro" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Nombre de Usuario</label>
                            <input asp-for="Nombre" class="form-control" required autocomplete="off" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Correo Electrónico</label>
                            <input asp-for="Correo" type="email" class="form-control" required />
                            <span asp-validation-for="Correo" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Apellido Paterno</label>
                            <input asp-for="ApellidoP" class="form-control" required />
                            <span asp-validation-for="ApellidoP" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Apellido Materno</label>
                            <input asp-for="ApellidoM" class="form-control" />
                            <span asp-validation-for="ApellidoM" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Contraseña Temporal</label>
                        <input asp-for="Contrasena" type="password" class="form-control" required />
                        <small class="text-muted">El usuario deberá cambiarla en su primer acceso.</small>
                        <span asp-validation-for="Contrasena" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-end mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-light me-2">Cancelar</a>
                        <button type="submit" class="btn btn-jewel-primary">Registrar Usuario</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>