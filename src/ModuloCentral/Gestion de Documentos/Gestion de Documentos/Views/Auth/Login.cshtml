@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card card-jewel">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold" style="color: var(--jewel-sapphire);">Acceso al Sistema</h2>
                    <p class="text-muted">Ingresa tus credenciales operativas</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger text-center shadow-sm">@ViewBag.Error</div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Username</label>
                        <input type="text" name="username" class="form-control" required placeholder="Ej: admin_sistema" autocomplete="off" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Contraseña</label>
                        <input type="password" name="contrasena" class="form-control" required placeholder="••••••••" />
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-jewel-primary btn-lg">Ingresar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>